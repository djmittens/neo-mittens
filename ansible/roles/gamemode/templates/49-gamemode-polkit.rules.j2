// /etc/polkit-1/rules.d/49-gamemode-polkit.rules
// Generated by neo-mittens ansible role `gamemode`. Do not edit by hand.
//
// Allows {{ target_user }} (and members of the gamemode group) to run
// gamemode helpers without auth prompts. Two polkit checks are involved
// in the typical flow:
//
//   1. com.feralinteractive.GameMode.{governor,gpu,cpu,procsys}-helper
//      Queried by gamemoded itself via dbus when a game registers.
//
//   2. org.freedesktop.policykit.exec
//      Queried by pkexec when it actually spawns the helper binary.
//      pkexec wraps the call in /usr/bin/env for env sanitization, so
//      polkit's `program` attribute is "/usr/bin/env" -- we must inspect
//      `command_line` to identify the real target.

polkit.addRule(function(action, subject) {
    var allowed_user = (subject.user == "{{ target_user }}" ||
                        subject.isInGroup("gamemode"));
    if (!allowed_user) {
        return undefined;  // fall through to default policy (deny)
    }

    // Set 1: native gamemode actions (queried via dbus from gamemoded)
    if (action.id == "com.feralinteractive.GameMode.governor-helper" ||
        action.id == "com.feralinteractive.GameMode.gpu-helper" ||
        action.id == "com.feralinteractive.GameMode.cpu-helper" ||
        action.id == "com.feralinteractive.GameMode.procsys-helper") {
        return polkit.Result.YES;
    }

    // Set 2: pkexec generic exec — match command_line because pkexec
    // wraps in /usr/bin/env so program=/usr/bin/env is uninformative.
    if (action.id == "org.freedesktop.policykit.exec") {
        var cmdline = action.lookup("command_line") || "";

        // Any binary under the gamemode helpers directory.
        if (cmdline.indexOf("{{ gamemode_helper_path_prefix }}") >= 0) {
            return polkit.Result.YES;
        }

        // Legacy split_lock_mitigate write via tee.
        if (cmdline.indexOf("{{ gamemode_split_lock_path }}") >= 0) {
            return polkit.Result.YES;
        }
    }
});
